{
  "name": "project-spip",
  "version": "1.3.1",
  "description": "PC에 흩어진 VSCode 프로젝트를 스캔해 간략한 설명과 함께 보여주는 로컬 대시보드",
  "type": "commonjs",
  "main": "electron/main.js",
  "bin": {
    "spip": "scan.js"
  },
  "scripts": {
    "scan": "node scan.js",
    "start": "electron .",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable",
    "release": "electron-builder --win --publish always",
    "start:web": "node server.js",
    "serve:http": "node server.js",
    "dev": "node scan.js && node server.js",
    "test": "node --test \"test/**/*.test.js\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "sortablejs": "1.15.6"
  },
  "license": "MIT"
}
